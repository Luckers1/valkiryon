generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String   
  email     String   @unique
  password  String
  role      Role     @default(USER)
  nr_cpf    String
  nr_cnpj   String
  phone     String
  nr_cep    String
  razao_social String
  nome_fantasia String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // Define o nome da tabela no banco como 'users'
}

enum Role {
  USER
  ADMIN
  MANAGER
  OPERATOR
}

model OlxToken {
  id            String   @id @default(uuid())
  accessToken   String
  refreshToken  String
  expiresAt     DateTime
  createdAt     DateTime @default(now())

    @@map("olxtoken")
}